@bot.message_handler(func=lambda m: True)
def handle_message(msg):
    global market_ok
    
    # Debug print
    print(f"📩 Message from {msg.from_user.id}: {msg.text}")
    
    if msg.from_user.id != USER_ID:
        print(f"⚠️ Unauthorized user: {msg.from_user.id}")
        return
    
    text = msg.text.strip().lower()
    
    # Handle /start command
    if text == "/start":
        bot.reply_to(msg, 
            "✅ Bot is alive!\n\n"
            "Commands:\n"
            "/market - Check market status\n"
            "/help - Show this help\n\n"
            "Or type 'market' to check")
        return
    
    # Handle /help command
    if text == "/help":
        bot.reply_to(msg,
            "📖 Help:\n\n"
            "Type 'market' to check market condition\n"
            "If market is good, you'll get a PROCEED button\n"
            "Press the button for deep analysis\n"
            "Bot will send BUY/SELL signal to algo")
        return
    
    # Handle market check
    if "மார்க்கெட்" in text or "market" in text:
        bot.send_message(USER_ID, "🔍 Analyzing market...")
        
        ok, message = analyze_market_basic()
        
        if ok:
            market_ok = True
            bot.send_message(USER_ID, 
                f"📊 Market Status:\n{message}\n\n"
                f"✅ Ready for analysis",
                reply_markup=get_proceed_button())
        else:
            market_ok = False
            bot.send_message(USER_ID, 
                f"⚠️ Market Status:\n{message}\n\n"
                f"❌ Entry not safe")
        return
    
    # Default response
    bot.reply_to(msg, "Type 'market' to check status or /help for commands")

