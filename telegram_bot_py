@bot.message_handler(func=lambda m: True)
def handle_message(msg):
    global market_ok

    if msg.from_user.id != USER_ID:
        return

    text = msg.text.strip().lower()

    if "மார்க்கெட்" in text or "market" in text:
        bot.send_message(USER_ID, "🔍 மார்க்கெட் அனலைஸ் செய்கிறேன்…")

        ok, message = analyze_market_basic()

        if ok:
            market_ok = True
            bot.send_message(USER_ID,
                f"📊 மார்க்கெட் நிலை:\n{message}\n\n"
                f"👉 நீங்கள் ஆணை செய்யலாம்.",
                reply_markup=get_proceed_button()
            )
        else:
            market_ok = False
            bot.send_message(USER_ID, f"{message}\n\n⛔ Entry Unsafe.")

        return

    bot.send_message(USER_ID, "❗ தயவு செய்து: 'மார்க்கெட் எப்படி?' என்று கேளுங்கள்.")


