import os
import time
import requests
import pytz
import telebot
from datetime import datetime
from telebot.types import InlineKeyboardMarkup, InlineKeyboardButton

# 1. ENV CONFIG & SAFETY CHECK
TOKEN = os.getenv("TELEGRAM_BOT_TOKEN")
USER_ID_STR = os.getenv("TELEGRAM_USER_ID", "0")
ALGO_URL = os.getenv("ALGO_URL")
WEBHOOK_SECRET = os.getenv("WEBHOOK_SECRET")

if not TOKEN or not ALGO_URL:
    raise Exception("CRITICAL: Environment Variables are missing!")

USER_ID = int(USER_ID_STR)
bot = telebot.TeleBot(TOKEN, parse_mode="HTML")
IST = pytz.timezone("Asia/Kolkata")

# Internal State
market_ok = False
trade_lock = False
last_analysis_time = 0

# 2. UTILITIES
def reset_state():
    global market_ok, trade_lock
    market_ok = False
    trade_lock = False

def get_proceed_button():
    markup = InlineKeyboardMarkup()
    markup.add(InlineKeyboardButton("✅ PROCEED (Trade Now)", callback_data="DO_DEEP"))
    return markup

# 3. ROBUST DATA FETCHING
def fetch_tv_data():
    try:
        url = "https://scanner.tradingview.com/india/scan"
        cols = ["close", "open", "high", "low", "volume", "RSI", "ADX", "VWAP"]
        payload = {
            "symbols": {"tickers": ["NSE:NIFTY"]},
            "columns": cols
        }
        res = requests.post(url, json=payload, timeout=10)
        d = res.json()["data"][0]["d"]
        # Mapped dictionary for safety
        return dict(zip(cols, d))
    except Exception as e:
        print(f"Fetch Error: {e}")
        return None

def analyze_market_basic():
    data = fetch_tv_data()
    if not data:
        return False, "⚠️ Data unavailable. Connection issue."

    score = 0
    # Fixing HTML entities (Using proper > and < signs)
    if data['close'] > data['open']: score += 1
    if abs(data['close'] - data['vwap']) / data['vwap'] * 100 < 0.30: score += 1
    if 35 <= data['RSI'] <= 65: score += 1
    if data['ADX'] > 15: score += 1
    if data['volume'] > 50000: score += 1

    if score >= 3:
        return True, f"✅ Market Stable (Score: {score}/5)"
    return False, f"❌ Market Risky (Score: {score}/5)"

# 4. ALGO WEBHOOK EXECUTION
def send_signal_to_algo(signal):
    global trade_lock
    payload = {"secret": WEBHOOK_SECRET, "signal": signal, "symbol": "NIFTY"}
    try:
        res = requests.post(ALGO_URL, json=payload, timeout=15)
        res_data = res.json() # Safety check for JSON
        if res_data.get("status") == "Success":
            bot.send_message(USER_ID, "🚀 **ORDER PLACED SUCCESSFULLY!**")
        else:
            bot.send_message(USER_ID, f"❌ Algo Rejected: {res_data.get('message', 'Unknown')}")
    except:
        bot.send_message(USER_ID, "❌ Critical: Algo Server Unreachable!")
    
    reset_state()

# 5. HANDLERS
@bot.callback_query_handler(func=lambda call: call.data == "DO_DEEP")
def handle_deep(call):
    global trade_lock, market_ok, last_analysis_time
    
    # Timeout check: If button pressed after 2 mins
    if time.time() - last_analysis_time > 120:
        bot.answer_callback_query(call.id, "⏰ Session Expired! Analyze again.")
        reset_state()
        return

    if not market_ok or trade_lock:
        bot.answer_callback_query(call.id, "⚠️ Already processing or invalid state.")
        return

    trade_lock = True
    bot.edit_message_text("🔄 Executing Order...", chat_id=USER_ID, message_id=call.message.message_id)
    
    # Quick Deep Check
    data = fetch_tv_data()
    bias = "BUY" if data['close'] > data['vwap'] else "SELL"
    send_signal_to_algo(bias)

@bot.message_handler(func=lambda m: True)
def handle_msg(msg):
    global market_ok, last_analysis_time
    if msg.from_user.id != USER_ID: return
    
    text = msg.text.lower()
    if "market" in text or "மார்க்கெட்" in text:
        ok, status = analyze_market_basic()
        market_ok = ok
        last_analysis_time = time.time()
        
        if ok:
            bot.send_message(USER_ID, status, reply_markup=get_proceed_button())
        else:
            bot.send_message(USER_ID, status)

# 6. RUN BOT
if __name__ == "__main__":
    print("🚀 Telegram Bot Started (Production Mode)")
    bot.polling(none_stop=True, interval=1, timeout=20)
