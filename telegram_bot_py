def get_proceed_button():
    markup = InlineKeyboardMarkup()
    btn = InlineKeyboardButton("✅ PROCEED (Deep Analysis)", callback_data="DO_DEEP")
    markup.add(btn)
    return markup


# =============================================================
#  CALLBACK HANDLER (Button Press)
# =============================================================

@bot.callback_query_handler(func=lambda call: True)
def callback_handler(call):
    global trade_lock

    if call.from_user.id != USER_ID:
        return

    if call.data == "DO_DEEP":

        if trade_lock:
            bot.answer_callback_query(call.id, "⛔ Trade already in progress.")
            return

        bot.answer_callback_query(call.id, "🔍 Deep Analysis Running…")
        trade_lock = True

        signal, reason = analyze_deep()

        if signal is None:
            bot.send_message(USER_ID, "❌ Deep analysis not implemented yet.")
            trade_lock = False
            return

        bot.send_message(USER_ID, f"📊 Deep Analysis Result:\n{reason}\n\n👉 Decision: <b>{signal}</b>")

        send_signal_to_algo(signal)


# =============================================================
#  SEND SIGNAL TO MAIN ALGO
# =============================================================

def send_signal_to_algo(signal):
    global trade_lock

    payload = {
        "secret": WEBHOOK_SECRET,
        "signal": signal,
        "symbol": "NIFTY",
        "token": "99926000",
        "price": "Market"
    }

    try:
        res = requests.post(ALGO_URL, json=payload, timeout=8)
        data = res.json()
    except Exception as e:
        bot.send_message(USER_ID, f"❌ Algo unreachable: {e}")
        trade_lock = False
        return

    # SUCCESS
    if data.get("status") == "Success":
        bot.send_message(USER_ID,
            f"✅ <b>ALGO SUCCESS</b>\n\n"
            f"{data.get('details')}\n"
            f"{data.get('analysis_match')}"
        )
        reset_state()
        return

    # ERROR FROM ALGO
    if data.get("status") == "Error":
        msg = data.get("message", "")
        bot.send_message(USER_ID, f"❌ Algo Error:\n{msg}")

        if "Unauthorized" in msg:
            bot.send_message(USER_ID, "⛔ Secret Key invalid!")
        trade_lock = False
        return

    # UNEXPECTED
    bot.send_message(USER_ID, f"⚠️ Unknown Algo Response:\n{data}")
    trade_lock = False


