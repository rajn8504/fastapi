def start_bot():
    print("🚀 Telegram Bot Started (Thread Mode)")
    while True:
        try:
            bot.infinity_polling(long_polling_timeout=30, timeout=20)
        except Exception as e:
            print("⚠️ BOT ERROR, Restarting:", e)
            time.sleep(2)
            continue
