def send_signal_to_algo(signal):
    global trade_lock

    payload = {
        "secret": WEBHOOK_SECRET,
        "signal": signal,
        "symbol": "NIFTY",
        "token": "99926000",
        "price": "Market"
    }

    try:
        res = requests.post(ALGO_URL, json=payload, timeout=8)
        data = res.json()
    except Exception as e:
        bot.send_message(USER_ID, f"❌ Algo unreachable: {e}")
        trade_lock = False
        return

    # SUCCESS
    if data.get("status") == "Success":
        bot.send_message(USER_ID,
            f"✅ <b>ALGO SUCCESS</b>\n\n"
            f"{data.get('details')}\n"
            f"{data.get('analysis_match')}"
        )
        reset_state()
        return

    # ERROR FROM ALGO
    if data.get("status") == "Error":
        msg = data.get("message", "")
        bot.send_message(USER_ID, f"❌ Algo Error:\n{msg}")

        if "Unauthorized" in msg:
            bot.send_message(USER_ID, "⛔ Secret Key invalid!")
        trade_lock = False
        return

    # UNEXPECTED
    bot.send_message(USER_ID, f"⚠️ Unknown Algo Response:\n{data}")
    trade_lock = False


